<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <Button
                android:id="@+id/btn_back_home"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="← 首页"
                android:textSize="13sp"
                android:minWidth="0dp"
                android:paddingHorizontal="12dp"
                android:layout_marginEnd="12dp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="摄像头 &amp; 人脸识别"
                android:textSize="20sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- ======== 模块一：Camera2 原生摄像头 ======== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#F5F5F5"
            android:padding="12dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="模块一：Android Camera2 摄像头"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#333333"
                android:layout_marginBottom="4dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⚠ 使用 Camera2 打开摄像头会导致机器人视觉能力暂时不可用"
                android:textSize="11sp"
                android:textColor="#FF6D00"
                android:layout_marginBottom="8dp" />

            <SurfaceView
                android:id="@+id/surface_camera_preview"
                android:layout_width="match_parent"
                android:layout_height="240dp"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center">

                <Button
                    android:id="@+id/btn_camera_open"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="打开摄像头"
                    android:layout_marginEnd="6dp" />

                <Button
                    android:id="@+id/btn_camera_close"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="关闭摄像头"
                    android:layout_marginEnd="6dp" />

                <Button
                    android:id="@+id/btn_camera_switch"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="切换前/后" />
            </LinearLayout>

            <TextView
                android:id="@+id/tv_camera2_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="就绪"
                android:textSize="13sp"
                android:textColor="#666666" />
        </LinearLayout>

        <!-- ======== 模块二：摄像头数据流共享 ======== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#F5F5F5"
            android:padding="12dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="模块二：摄像头数据流共享（SurfaceShare）"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#333333"
                android:layout_marginBottom="4dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="通过 VisionSDK 共享摄像头数据，不影响机器人视觉能力"
                android:textSize="11sp"
                android:textColor="#999999"
                android:layout_marginBottom="8dp" />

            <ImageView
                android:id="@+id/iv_surface_share"
                android:layout_width="match_parent"
                android:layout_height="240dp"
                android:layout_marginBottom="8dp"
                android:background="#000000"
                android:scaleType="fitCenter" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center">

                <Button
                    android:id="@+id/btn_share_start"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="开始共享"
                    android:layout_marginEnd="6dp" />

                <Button
                    android:id="@+id/btn_share_stop"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="停止共享" />
            </LinearLayout>

            <TextView
                android:id="@+id/tv_share_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="就绪"
                android:textSize="13sp"
                android:textColor="#666666" />
        </LinearLayout>

        <!-- ======== 模块三：人脸识别 ======== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#F5F5F5"
            android:padding="12dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="模块三：人脸识别"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#333333"
                android:layout_marginBottom="4dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="基于 VisionSDK 的人员检测与识别（本地能力，识别需联网）"
                android:textSize="11sp"
                android:textColor="#999999"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginBottom="6dp">

                <Button
                    android:id="@+id/btn_face_start"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="开始检测"
                    android:layout_marginEnd="6dp" />

                <Button
                    android:id="@+id/btn_face_stop"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="停止检测"
                    android:layout_marginEnd="6dp" />

                <Button
                    android:id="@+id/btn_face_refresh"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="刷新人员" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginBottom="8dp">

                <Button
                    android:id="@+id/btn_sdk_switch_front"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="SDK切前置"
                    android:layout_marginEnd="6dp" />

                <Button
                    android:id="@+id/btn_sdk_switch_back"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="SDK切后置" />
            </LinearLayout>

            <TextView
                android:id="@+id/tv_face_info"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="尚未检测到人员"
                android:textSize="13sp"
                android:textColor="#333333"
                android:lineSpacingExtra="4dp"
                android:padding="8dp"
                android:background="#FFFFFF"
                android:minHeight="80dp" />

            <TextView
                android:id="@+id/tv_face_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="就绪"
                android:textSize="13sp"
                android:textColor="#666666" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
